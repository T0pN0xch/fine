<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/finance_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/finance_widget_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitCenter"
        android:visibility="gone"
        android:contentDescription="@string/finance_widget_description" />

    <TextView
        android:id="@+id/finance_widget_placeholder"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:background="@drawable/finance_widget_background"
        android:padding="16dp"
        android:text="@string/finance_widget_placeholder"
        android:textColor="#8A84A8"
        android:textSize="14sp" />

</FrameLayout>
